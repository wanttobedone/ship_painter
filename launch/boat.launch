<launch>

    <!-- 环境变量配置 -->
    <env name="PX4_SIM_MODEL" value="iris" />
    <!-- 禁用Gazebo在线模型下载，使用本地模型 -->
    <env name="GAZEBO_MODEL_DATABASE_URI" value="" />
    <!-- 添加模型搜索路径：ship_painter模型 -> 本地下载的模型 -> mavlink_sitl_gazebo模型 -->
    <env name="GAZEBO_MODEL_PATH" value="$(find ship_painter)/models:$(env HOME)/.gazebo/models:$(find mavlink_sitl_gazebo)/models:$(optenv GAZEBO_MODEL_PATH)" />


    <!-- 仿真环境参数 -->
    <arg name="est" default="ekf2"/>
    <arg name="vehicle" default="iris"/>
    <arg name="world" default="$(find ship_painter)/worlds/ship.world"/>
    <!-- iris_vins_fusion.sdf: 包含立体相机、IMU、GPS、风插件、机体力插件 -->
    <!-- 如果不需要扰动插件且不用VINS，可换回原版: $(find mavlink_sitl_gazebo)/models/iris_stereo_camera/iris_stereo_camera.sdf -->
    <arg name="sdf" default="$(find ship_painter)/models/iris_vins_fusion.sdf"/>

    <!-- 船体模型参数（可配置） -->
    <arg name="model_name" default="S5_4" doc="S5_4 reconstructed mesh"/>
    <!-- <arg name="model_name" default="test" doc="model_for_demo"/> -->
    <arg name="model_stl" default="$(find ship_painter)/models/S5_4.stl"/>
    <!-- PLY点云工作流：直接用点云文件，不需要STL/SDF -->
    <arg name="model_path" default="$(find ship_painter)/models/S5_4.ply"/>

    <!-- 任务部署参数（统一坐标方案） --><!--路径规划参数在boat2.launch里改-->
    <arg name="mission_forward_distance" default="3.0" doc="目标物近侧到mission0原点的前向距离(m)"/>
    <arg name="mission_fcu_ground_height" default="-0.3" doc="起飞前飞控到地面的高度(m)"/>
    <arg name="mission_bottom_clearance" default="0.0" doc="底部离地安全间隙(m)"/>
    <arg name="spray_dist" default="1.0"/>

    <!-- PX4 SITL 仿真核心 -->
    <include file="$(find px4)/launch/mavros_posix_sitl.launch">
        <arg name="est" value="$(arg est)"/>
        <arg name="vehicle" value="$(arg vehicle)"/>
        <arg name="world" value="$(arg world)"/>
        <arg name="sdf" value="$(arg sdf)"/>
    </include>

    <!-- auto_spawner: 仅STL/SDF工作流可用，PLY模式下禁用 -->
    <!-- 如需在Gazebo中显示模型，需提供STL/SDF文件，取消注释并设置model_stl/model_sdf参数 -->
    
    <!-- <arg name="model_stl" default="$(find ship_painter)/models/test.stl"/> -->
    <arg name="model_sdf" default="$(find ship_painter)/models/S5_4.sdf"/>
    <node name="auto_spawner" pkg="ship_painter" type="auto_spawn_model.py" output="screen">
        <param name="stl_path" value="$(arg model_stl)"/>
        <param name="sdf_path" value="$(arg model_sdf)"/>
        <param name="model_name" value="$(arg model_name)"/>
        <param name="mission_forward_distance" value="$(arg mission_forward_distance)"/>
        <param name="mission_fcu_ground_height" value="$(arg mission_fcu_ground_height)"/>
        <param name="mission_bottom_clearance" value="$(arg mission_bottom_clearance)"/>
    </node>
   

    <!-- PX4 EKF2 Vision Parameters Configuration -->
    <!--
    This script configures PX4's EKF2 to fuse vision data from VINS-Fusion
    Enables position, velocity, and yaw fusion for vision-aided navigation
    Uses Python script with MAVROS services for more reliable parameter setting
    -->
    <node name="set_px4_vision_params" pkg="ship_painter" type="set_px4_vision_params.py"
          launch-prefix="bash -c 'sleep 10; $0 $@' "
          output="screen"/>
    <!--
    视觉融合验证:
      rostopic echo /mavros/vision_pose/pose             # 检查VINS数据是否到达MAVROS
      rostopic echo /mavros/local_position/pose          # 检查PX4融合后的位置估计
      rosrun mavros mavparam get EKF2_EV_CTRL            # 确认参数已设置

    使用其他模型示例:
      roslaunch ship_painter boat.launch \
        model_name:=test_ship \
        model_stl:=$(find ship_painter)/models/test.stl \
        model_sdf:=$(find ship_painter)/models/test.sdf \
        mission_forward_distance:=3.0
    -->

</launch>
